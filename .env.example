# ── DocuMindAI Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Core ───────────────────────────────────────────────────────────────────────
ENV=production
SECRET_KEY=change_this_to_a_long_random_string_in_production

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, works locally and on Railway)
DATABASE_URL=sqlite:///./documind.db
# PostgreSQL (for production scale)
# DATABASE_URL=postgresql://user:password@host:5432/documindai

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Add multiple keys separated by commas for key rotation (avoids quota errors)
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.8
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_CONTINUATION_ROUNDS=2

# ── RAG Settings ───────────────────────────────────────────────────────────────
TOP_K_RESULTS=15
CHUNK_SIZE=1800
CHUNK_OVERLAP=250

# ── Storage ────────────────────────────────────────────────────────────────────
STORAGE_PATH=./storage

# ── SMTP (for OTP password reset) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ── Deployment ────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway/Render. Override only if needed.
# PORT=8000
