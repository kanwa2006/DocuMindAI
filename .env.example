# ═══════════════════════════════════════════════════════════════════════════════
# DocuMindAI — Environment Configuration
# Copy this file to .env and fill in your credentials.
#
# GitHub Student Developer Pack stack:
#   Database : Supabase (Postgres + pgvector)  → https://supabase.com
#   Redis    : Upstash                         → https://upstash.com
#   Email    : SendGrid                        → https://sendgrid.com
#   Hosting  : Railway / Render / DigitalOcean
#   Domain   : Free .tech domain via Pack
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Security ──────────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=change_me_to_a_random_64_char_secret
CSRF_SECRET_KEY=change_me_to_another_random_secret

# ── Database — Supabase (Student Pack) ───────────────────────────────────────
# Option A: paste the full Supabase connection string (recommended)
#   Found at: Supabase Dashboard → Settings → Database → Connection string → URI
#   Make sure to select "Transaction" mode (port 6543) for pgbouncer pooling.
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<ref>.supabase.co:5432/postgres
#
# Option B: individual fields (used if DATABASE_URL is not set)
POSTGRES_SERVER=db.<ref>.supabase.co
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_supabase_db_password
POSTGRES_DB=postgres
#
# Local dev fallback (docker-compose spins up a local Postgres):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/documind

# ── Redis — Upstash (Student Pack, free tier) ─────────────────────────────────
# Found at: Upstash Console → Database → Connect → .env tab
# Upstash uses TLS (rediss://) — make sure the URL starts with rediss://
REDIS_URL=rediss://:<password>@<host>.upstash.io:6379
CELERY_BROKER_URL=rediss://:<password>@<host>.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://:<password>@<host>.upstash.io:6379
#
# Local dev fallback:
# REDIS_URL=redis://localhost:6380/0
# CELERY_BROKER_URL=redis://localhost:6380/0
# CELERY_RESULT_BACKEND=redis://localhost:6380/0

# ── LLM — Gemini (your own keys) ─────────────────────────────────────────────
# At least GEMINI_API_KEY_1 is required. Add _2, _3 … for key rotation.
GEMINI_API_KEY_1=your_gemini_api_key_here
# GEMINI_API_KEY_2=optional_second_key_for_rotation
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# ── Email — SendGrid (Student Pack) ──────────────────────────────────────────
# SendGrid SMTP relay (free 100 emails/day on student pack)
# Settings → Email API → Integration Guide → SMTP Relay
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.tech
EMAILS_FROM_NAME=DocuMindAI
EMAILS_FROM_ADDRESS=noreply@yourdomain.tech
ADMIN_EMAIL=your@email.com

# Brevo SMTP — keep as fallback if not using SendGrid
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_USER=your_brevo_login_email
# BREVO_SMTP_PASSWORD=your_brevo_smtp_key

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local           # local | s3
STORAGE_PATH=./storage
# S3 / Supabase Storage (set STORAGE_PROVIDER=s3 to enable):
# S3_BUCKET=your-bucket-name
# S3_REGION=ap-south-1
# S3_ENDPOINT_URL=https://<ref>.supabase.co/storage/v1/s3  # Supabase Storage S3 API
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ── Billing — Razorpay sandbox (India-first payments) ────────────────────────
# Set RAZORPAY_ENABLED=true to use real checkout; false = sandbox/dev mode
RAZORPAY_ENABLED=false
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx      # use rzp_test_ prefix for sandbox
# RAZORPAY_KEY_SECRET=your_razorpay_secret
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── SMS — Twilio (optional, phone OTP) ───────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
LOG_LEVEL=INFO
OTEL_ENABLED=false
PROMETHEUS_ENABLED=false

# ── Vector backend ────────────────────────────────────────────────────────────
VECTOR_BACKEND=pgvector         # pgvector (default, indexed ANN) | faiss (NumPy dev fallback) | qdrant
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
