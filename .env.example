# Shared configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=documind
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

# Gemini API keys — supply EITHER form, the backend accepts both:
#   1) Numbered (recommended):  GEMINI_API_KEY_1=..., GEMINI_API_KEY_2=...
#   2) Single comma-separated:  GEMINI_API_KEYS=k1,k2,k3
# At least one key is required, otherwise LLM calls return mock responses.
GEMINI_API_KEY_1=your_first_key_here
# GEMINI_API_KEY_2=your_second_key_here


# Twilio — SMS phone OTP (Phase 16)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Brevo SMTP — transactional emails (welcome, trial nudges, upgrade reminders)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_login_email
BREVO_SMTP_PASSWORD=your_brevo_smtp_key
EMAILS_FROM_NAME=DocuMindAI
EMAILS_FROM_ADDRESS=noreply@documindai.com

# Phase 20 — Admin alert email (receives health alerts, digests, subscription notices)
ADMIN_EMAIL=your@email.com
