# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
*.env.local
*.env.production

# ── Database (contains real user data — never commit) ─────────────────────────
*.db
*.sqlite
*.sqlite3

# ── FAISS indexes (regenerated on first use) ──────────────────────────────────
storage/*/index/
storage/*/index.faiss
storage/*/index.pkl

# ── Uploaded files (can be large, private) ────────────────────────────────────
files/
storage/*/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Misc project scripts (not needed in production) ───────────────────────────
fix_and_run.py
fix_chain.py
fix_routes.py
check.py
test_*.py
generate_endterm_report.py
migrate.py
toc_analysis.json
