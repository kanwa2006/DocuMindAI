# Shared Infrastructure Config for Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=documind
POSTGRES_PORT=5432
REDIS_PORT=6379

GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.0-flash


# Twilio — SMS phone OTP (Phase 16)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Brevo SMTP — transactional emails (welcome, trial nudges, upgrade reminders)
# Sign up free at brevo.com → SMTP & API → Generate SMTP key
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_login_email
BREVO_SMTP_PASSWORD=your_brevo_smtp_key
EMAILS_FROM_NAME=DocuMindAI
EMAILS_FROM_ADDRESS=noreply@documindai.com

# Phase 20 — Admin alert email (receives health alerts, digests, subscription notices)
ADMIN_EMAIL=your@email.com
