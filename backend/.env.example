ENVIRONMENT=development

# Security
AUTH_SECRET_KEY=dev_secret_key_change_in_prod
CSRF_SECRET_KEY=dev_csrf_secret_change_in_prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
FRONTEND_URL=http://localhost:3000

# Database
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=documind
DATABASE_URL=postgresql+asyncpg://postgres.esuiabqtuscwykixlifw:JvwZz3qNHZxBqWuR@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage

# Optional S3-Compatible Providers
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OCR / Extraction
CHUNK_SIZE=1800
CHUNK_OVERLAP=300
OCR_CONFIDENCE_THRESHOLD=0.80
MAX_UPLOAD_MB=200

# Gemini / LLM
GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_TOP_P=0.8
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_CONTINUATION_ROUNDS=2
TOP_K_RESULTS=20

# Vector Backend
VECTOR_BACKEND=faiss
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Monitoring
OTEL_ENABLED=true
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO
